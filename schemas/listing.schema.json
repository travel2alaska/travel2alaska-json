{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Listing",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "region": { "type": "string" },
    "city": { "type": "string" },
    "phone": { "type": "string" },
    "website": { "type": "string", "format": "uri" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tier": {
      "type": "string",
      "enum": ["free", "pro", "sponsored"],
      "default": "free"
    }
  },
  "required": ["id", "name", "category", "region", "city", "tier"]
}
