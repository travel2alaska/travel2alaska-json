{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "location": { "type": "string" },
    "dates": {
      "type": "object",
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      },
      "required": ["start"]
    },
    "category": { "type": "string" },
    "description": { "type": "string" },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["official", "facebook", "tickets"] },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["type", "url"]
      }
    }
  },
  "required": ["id", "name", "location", "dates", "category", "description"]
}
